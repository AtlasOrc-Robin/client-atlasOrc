# Supabase — required for contact form, newsletter, and review collection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cal.com — optional, set your Cal.com username for booking embed
NEXT_PUBLIC_CALCOM_USERNAME=atlasorc

# Site URL — used for OG tags and sitemap
NEXT_PUBLIC_SITE_URL=https://atlasorc.com
